# Copy to deploy/openclaw-sidecar.env and pass with:
#   docker compose -f deploy/compose.yaml -f deploy/compose.openclaw-sidecar.override.yaml --env-file deploy/openclaw-sidecar.env --profile sidecar ...
#
# This file drives compose interpolation for the real OpenClaw runtime on topology B / sidecar proxy.
# The paired sidecar proxy still owns the observed-runtime session lineage contract.

OPENCLAW_SIDECAR_RUNTIME_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_SIDECAR_RUNTIME_PULL_POLICY=always
OPENCLAW_SIDECAR_RUNTIME_ENV_FILE=./openclaw-sidecar.runtime.env.sample
OPENCLAW_SIDECAR_RUNTIME_HTTP_PROXY=http://127.0.0.1:8080
OPENCLAW_SIDECAR_RUNTIME_HTTPS_PROXY=http://127.0.0.1:8080
OPENCLAW_SIDECAR_RUNTIME_NO_PROXY=hostd,localhost,127.0.0.1

# Paired proxy lineage contract. Keep these stable while you verify one OpenClaw sidecar runtime.
SIDECAR_OPENCLAW_SESSION_ID=sess_openclaw_sidecar_proxy
SIDECAR_OPENCLAW_AGENT_ID=openclaw-main
SIDECAR_OPENCLAW_WORKSPACE_ID=agent-auditor

AUDITOR_MODE=enforce_preview
HOSTD_POLL_INTERVAL_MS=1000
HOSTD_RUST_LOG=info
