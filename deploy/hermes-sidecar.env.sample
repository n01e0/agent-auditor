# Copy to deploy/hermes-sidecar.env and pass with:
#   docker compose -f deploy/compose.yaml -f deploy/compose.hermes-sidecar.override.yaml --env-file deploy/hermes-sidecar.env --profile sidecar ...
#
# This file drives compose interpolation for the real Hermes runtime on topology B / sidecar proxy.
# The paired sidecar proxy still owns the observed-runtime session lineage contract.

HERMES_SIDECAR_RUNTIME_IMAGE=ghcr.io/hermes/hermes:latest
HERMES_SIDECAR_RUNTIME_PULL_POLICY=always
HERMES_SIDECAR_RUNTIME_ENV_FILE=./hermes-sidecar.runtime.env.sample
HERMES_SIDECAR_RUNTIME_HTTP_PROXY=http://127.0.0.1:8080
HERMES_SIDECAR_RUNTIME_HTTPS_PROXY=http://127.0.0.1:8080
HERMES_SIDECAR_RUNTIME_NO_PROXY=hostd,localhost,127.0.0.1

# Paired proxy lineage contract. Keep these stable while you verify one Hermes sidecar runtime.
SIDECAR_HERMES_SESSION_ID=sess_hermes_sidecar_proxy
SIDECAR_HERMES_AGENT_ID=hermes-main
SIDECAR_HERMES_WORKSPACE_ID=agent-auditor

AUDITOR_MODE=enforce_preview
HOSTD_POLL_INTERVAL_MS=1000
HOSTD_RUST_LOG=info
