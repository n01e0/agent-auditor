# Copy to deploy/openclaw-forward-proxy.env and pass with:
#   docker compose -f deploy/compose.yaml -f deploy/compose.openclaw-forward-proxy.override.yaml --env-file deploy/openclaw-forward-proxy.env ...
#
# This file drives compose interpolation for the real OpenClaw runtime on topology A / forward proxy.
# The paired proxy still owns the observed-runtime session lineage contract.

OPENCLAW_RUNTIME_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_RUNTIME_PULL_POLICY=always
OPENCLAW_RUNTIME_ENV_FILE=./openclaw-forward-proxy.runtime.env.sample
OPENCLAW_RUNTIME_HTTP_PROXY=http://openclaw-forward-proxy:8080
OPENCLAW_RUNTIME_HTTPS_PROXY=http://openclaw-forward-proxy:8080
OPENCLAW_RUNTIME_NO_PROXY=hostd,localhost,127.0.0.1

# Paired proxy lineage contract. Keep these stable while you verify one OpenClaw runtime.
OPENCLAW_SESSION_ID=sess_openclaw_forward_proxy
OPENCLAW_AGENT_ID=openclaw-main
OPENCLAW_WORKSPACE_ID=agent-auditor
OPENCLAW_FORWARD_PROXY_PORT=18080

AUDITOR_MODE=enforce_preview
HOSTD_POLL_INTERVAL_MS=1000
HOSTD_RUST_LOG=info
