# Copy to deploy/compose.env or pass with --env-file.

HOSTD_IMAGE=rust:1.93-bookworm
HOSTD_POLL_INTERVAL_MS=1000
HOSTD_REMOTE_INGRESS_PORT=19090
HOSTD_REMOTE_INGRESS_TIMEOUT_SEC=2
HOSTD_RUST_LOG=info

OPENCLAW_SESSION_ID=sess_openclaw_forward_proxy
OPENCLAW_AGENT_ID=openclaw-main
OPENCLAW_WORKSPACE_ID=agent-auditor
OPENCLAW_GITHUB_REPO=n01e0/agent-auditor
OPENCLAW_PROBE_INTERVAL_SEC=30
OPENCLAW_FORWARD_PROXY_PORT=18080

HERMES_SESSION_ID=sess_hermes_forward_proxy
HERMES_AGENT_ID=hermes-main
HERMES_WORKSPACE_ID=agent-auditor
HERMES_GMAIL_USER=me
HERMES_PROBE_INTERVAL_SEC=30
HERMES_FORWARD_PROXY_PORT=18081

SIDECAR_OPENCLAW_SESSION_ID=sess_openclaw_sidecar_proxy
SIDECAR_OPENCLAW_AGENT_ID=openclaw-main
SIDECAR_OPENCLAW_WORKSPACE_ID=agent-auditor
SIDECAR_OPENCLAW_GITHUB_REPO=n01e0/agent-auditor
SIDECAR_OPENCLAW_PROBE_INTERVAL_SEC=30

SIDECAR_HERMES_SESSION_ID=sess_hermes_sidecar_proxy
SIDECAR_HERMES_AGENT_ID=hermes-main
SIDECAR_HERMES_WORKSPACE_ID=agent-auditor
SIDECAR_HERMES_GMAIL_USER=me
SIDECAR_HERMES_PROBE_INTERVAL_SEC=30

AUDITOR_MODE=enforce_preview
