# Copy to deploy/hermes-forward-proxy.env and pass with:
#   docker compose -f deploy/compose.yaml -f deploy/compose.hermes-forward-proxy.override.yaml --env-file deploy/hermes-forward-proxy.env ...
#
# This file drives compose interpolation for the real Hermes runtime on topology A / forward proxy.
# The paired proxy still owns the observed-runtime session lineage contract.
# Runtime proxy/cert handoff contract for Hermes:
# - compose injects HTTP_PROXY / HTTPS_PROXY / NO_PROXY from the values below
# - the paired proxy sends observed-runtime envelopes to AUDITOR_REMOTE_INGRESS_ADDR
# - compose mounts HERMES_RUNTIME_PROXY_CA_CERT at HERMES_RUNTIME_PROXY_CA_CERT_PATH
# - if Hermes or bundled tooling needs explicit lowercase proxy aliases or client-specific
#   CA env vars, mirror the same values/path inside deploy/hermes-forward-proxy.runtime.env

HERMES_RUNTIME_IMAGE=ghcr.io/hermes/hermes:latest
HERMES_RUNTIME_PULL_POLICY=always
HERMES_RUNTIME_ENV_FILE=./hermes-forward-proxy.runtime.env.sample
HERMES_RUNTIME_HTTP_PROXY=http://hermes-forward-proxy:8080
HERMES_RUNTIME_HTTPS_PROXY=http://hermes-forward-proxy:8080
HERMES_RUNTIME_NO_PROXY=hostd,localhost,127.0.0.1
HERMES_RUNTIME_PROXY_CA_CERT=./local/mitmproxy-ca/hermes/mitmproxy-ca-cert.pem
HERMES_RUNTIME_PROXY_CA_CERT_PATH=/opt/agent-auditor/certs/mitmproxy-ca-cert.pem
AUDITOR_REMOTE_INGRESS_ADDR=hostd:19090

# Paired proxy lineage contract. Keep these stable while you verify one Hermes runtime.
HERMES_SESSION_ID=sess_hermes_forward_proxy
HERMES_AGENT_ID=hermes-main
HERMES_WORKSPACE_ID=agent-auditor
HERMES_FORWARD_PROXY_PORT=18081

AUDITOR_MODE=enforce_preview
HOSTD_POLL_INTERVAL_MS=1000
HOSTD_RUST_LOG=info
