# Sample environment overrides for agent-auditor-hostd.service
# Install to /etc/agent-auditor/agent-auditor-hostd.env and adjust for your host.

# Installed binary path. Keep this outside the source tree.
AGENT_AUDITOR_HOSTD_BIN=/usr/local/bin/agent-auditor-hostd

# Durable runtime state root. Default service artifact uses /var/lib/agent-auditor-hostd.
# Override this only if you need a different host-local persistent path.
AGENT_AUDITOR_HOSTD_STATE_DIR=/var/lib/agent-auditor-hostd

# Foreground daemon poll interval in milliseconds.
AGENT_AUDITOR_HOSTD_POLL_INTERVAL_MS=250

# Remote-ingress listener for proxy-to-hostd handoff.
AGENT_AUDITOR_HOSTD_REMOTE_INGRESS_LISTEN=0.0.0.0:19090
